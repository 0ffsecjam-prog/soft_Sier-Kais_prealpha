generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ENUMS via string fields (SQLite no soporta enums nativos)
// Role: ADMIN | CANCHA | CLIENTE
// RecordingStatus: UPLOADING | READY | FAILED
// PaymentType: RECORDING | DOWNLOAD | RESERVATION | VIDEO_BUNDLE | CASH_SALE
// PaymentStatus: SIMULATED | PAID | FAILED | FREE
// PaymentMethod: SIMULATED | CASH | CARD
// LogLevel: DEBUG | INFO | WARN | ERROR | AUDIT
// TokenKind: CANCHA | CLIENTE_SHARE | ADMIN_CASH
// ReservationStatus: CONFIRMED | CANCELLED

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          String
  createdAt     DateTime @default(now())

  complex       Complex?  @relation("ComplexOwner")
  claims        Claim[]
  tokensCreated AccessToken[] @relation("TokenCreator")
  reservations  Reservation[] @relation("UserReservations")
  sharesCreated ShareLink[]   @relation("ShareCreator")
  logs          Log[]
}

model Complex {
  id               String   @id @default(cuid())
  name             String
  address          String
  lat              Float?
  lng              Float?
  ownerId          String   @unique
  revenueSharePct  Int      @default(7000)   // 70.00% en basis points
  createdAt        DateTime @default(now())

  owner            User     @relation("ComplexOwner", fields: [ownerId], references: [id])
  courts           Court[]
}

model Court {
  id                  String   @id @default(cuid())
  name                String
  complexId           String
  slotDurationMin     Int      @default(60)
  pricePerSlotCents   Int      @default(0)
  openingHour         Int      @default(8)   // hora local 0-23 (default si no hay weeklySchedule)
  closingHour         Int      @default(23)  // hora local 0-23
  weeklySchedule      String?                // JSON: {sun,mon,tue,wed,thu,fri,sat}: {open,close,isOpen}
  status              String   @default("ACTIVE")  // ACTIVE | MAINTENANCE | UNAVAILABLE
  statusMessage       String?                // aviso libre para mostrar al cliente
  createdAt           DateTime @default(now())

  complex      Complex            @relation(fields: [complexId], references: [id], onDelete: Cascade)
  recordings   Recording[]
  reservations Reservation[]
  blockedDates CourtBlockedDate[]

  @@index([complexId])
}

model CourtBlockedDate {
  id        String   @id @default(cuid())
  courtId   String
  date      DateTime                  // medianoche local del día bloqueado
  reason    String?
  createdAt DateTime @default(now())

  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([courtId, date])
  @@index([courtId, date])
}

model Recording {
  id                String   @id @default(cuid())
  courtId           String
  reservationId     String?
  title             String
  recordedAt        DateTime
  durationSec       Int      @default(0)
  filePath          String
  thumbnailPath     String?
  priceCents        Int
  downloadFeeCents  Int
  status            String   @default("READY")
  deletedAt         DateTime?
  createdAt         DateTime @default(now())

  court        Court        @relation(fields: [courtId], references: [id], onDelete: Cascade)
  reservation  Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  tokens       AccessToken[]
  claims       Claim[]
  shareLinks   ShareLink[]

  @@index([courtId])
  @@index([recordedAt])
  @@index([reservationId])
}

model AccessToken {
  id                  String    @id @default(cuid())
  code                String    @unique
  recordingId         String
  kind                String    @default("CANCHA")    // CANCHA | CLIENTE_SHARE | ADMIN_CASH
  priceOverrideCents  Int?      // null → usa Recording.priceCents
  maxUses             Int?
  usedCount           Int       @default(0)
  expiresAt           DateTime?
  createdById         String
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())

  recording     Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  createdBy     User      @relation("TokenCreator", fields: [createdById], references: [id])
  claims        Claim[]

  @@index([recordingId])
  @@index([code])
}

model Claim {
  id                 String    @id @default(cuid())
  userId             String
  recordingId        String
  tokenId            String
  claimedAt          DateTime  @default(now())
  pricePaidCents     Int
  hasDownloadAccess  Boolean   @default(false)
  downloadPaidAt     DateTime?
  downloadFeeCents   Int?
  revokedAt          DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording  Recording   @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  token      AccessToken @relation(fields: [tokenId], references: [id])
  payments   Payment[]

  @@index([userId])
  @@index([recordingId])
  @@index([userId, recordingId])
}

model Reservation {
  id               String   @id @default(cuid())
  userId           String
  courtId          String
  startsAt         DateTime
  endsAt           DateTime
  status           String   @default("CONFIRMED")     // CONFIRMED | CANCELLED
  slotPriceCents   Int                                // snapshot del precio de la cancha
  includesVideo    Boolean  @default(false)           // si el cliente compró el video bundled
  videoPriceCents  Int?                               // snapshot precio video bundled
  cancelledAt      DateTime?
  createdAt        DateTime @default(now())

  user       User        @relation("UserReservations", fields: [userId], references: [id], onDelete: Cascade)
  court      Court       @relation(fields: [courtId], references: [id], onDelete: Cascade)
  payments   Payment[]
  recordings Recording[]

  @@index([courtId, startsAt])
  @@index([userId])
  @@index([status])
}

model ShareLink {
  id            String   @id @default(cuid())
  token         String   @unique
  recordingId   String
  createdById   String
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())

  recording     Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  createdBy     User      @relation("ShareCreator", fields: [createdById], references: [id])

  @@index([token])
  @@index([recordingId])
  @@index([createdById])
}

model Payment {
  id            String   @id @default(cuid())
  claimId       String?
  reservationId String?
  type          String                   // RECORDING | DOWNLOAD | RESERVATION | VIDEO_BUNDLE | CASH_SALE
  amountCents   Int
  status        String   @default("SIMULATED")
  paymentMethod String?                  // SIMULATED | CASH | CARD
  externalRef   String?
  createdAt     DateTime @default(now())

  claim       Claim?       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([reservationId])
  @@index([createdAt])
}

model ConfigSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model SignupRequest {
  id              String   @id @default(cuid())
  status          String   @default("NEW")   // NEW | CONTACTED | CONVERTED | REJECTED

  // Contacto
  contactName     String
  email           String
  phone           String
  role            String?                     // cargo: dueño, encargado, etc.

  // Complejo
  businessName    String
  province        String
  city            String?
  address         String?
  numberOfCourts  Int
  courtTypes      String                       // JSON array de tipos
  surfaceType     String?                      // INDOOR | OUTDOOR | MIXED

  // Operación / calificación
  matchesPerWeek  String?                      // rango (texto)
  hasCameras      String?                      // ALL | SOME | NONE
  hasInternet     String?                      // YES | NO | PARTIAL
  referralSource  String?
  message         String?

  // Gestión interna
  adminNotes      String?
  convertedUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  context   String?   // JSON serializado
  userId    String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([level])
}
