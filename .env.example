# Database (SQLite local). Para Postgres usa: postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"

# Auth.js
AUTH_SECRET="cambiar-esto-en-produccion-32-bytes-min"
# trustHost: Auth.js infiere el origen (host + puerto) desde el request.
# IMPORTANTE: no setees AUTH_URL/NEXTAUTH_URL en desarrollo. Si lo fijás a
# http://localhost:3000 y el dev server arranca en otro puerto (3001, etc.),
# los redirects de login/logout te mandarían al puerto equivocado.
# En producción detrás de un dominio fijo, podés setear AUTH_URL si lo necesitás.
AUTH_TRUST_HOST=true

# Storage local
VIDEO_STORAGE_PATH="./storage/videos"
THUMBNAIL_STORAGE_PATH="./storage/thumbnails"
